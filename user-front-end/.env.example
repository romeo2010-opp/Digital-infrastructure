VITE_DATA_SOURCE=api
# Leave empty in local dev when using Vite proxy + tunnel.
# Set only when frontend and backend are on different hosts.
VITE_API_BASE_URL=
# Dev proxy target used by Vite server for /auth, /api and /ws.
VITE_DEV_API_TARGET=http://localhost:4000
VITE_DEV_PORT=5173
VITE_USER_ACCESS_TOKEN=
VITE_ALLOW_ENV_USER_TOKEN_FALLBACK=false
VITE_APP_TIME_ZONE=Africa/Blantyre

VITE_MAPBOX_TOKEN=
# Optional custom style URL
VITE_MAPBOX_STYLE_URL=

# Optional HMR overrides for mobile/tunnel/proxy-based dev.
# Examples:
# VITE_HMR_PROTOCOL=ws
# VITE_HMR_HOST=192.168.1.40
# VITE_HMR_CLIENT_PORT=5173
# VITE_HMR_PROTOCOL=wss
# VITE_HMR_HOST=my-app.trycloudflare.com
# VITE_HMR_CLIENT_PORT=443
# VITE_HMR_PATH=/__vite_ws
VITE_HMR_PROTOCOL=
VITE_HMR_HOST=
VITE_HMR_PORT=
VITE_HMR_CLIENT_PORT=
VITE_HMR_PATH=
VITE_HMR_TIMEOUT=

# Enable polling if your filesystem or Docker bind mount causes missed file events.
VITE_WATCH_USE_POLLING=false
VITE_WATCH_POLLING_INTERVAL=500
