    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.17.1",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7",
    "ws": "^8.19.0",
